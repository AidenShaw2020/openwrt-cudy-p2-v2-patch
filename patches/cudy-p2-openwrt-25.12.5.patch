+static inline void writel_masked(void __iomem *addr, u32 clear_mask,
+				 u32 set_mask)
+{
+	u32 val = readl(addr);
+
+	val &= ~clear_mask;
+	val |= set_mask;
+	writel(val, addr);
+}
