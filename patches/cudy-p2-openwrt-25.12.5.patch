diff --git a/target/linux/mediatek/filogic/base-files/etc/init.d/sprd-modem b/target/linux/mediatek/filogic/base-files/etc/init.d/sprd-modem
new file mode 100755
index 0000000000..cb26cb43e2
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/etc/init.d/sprd-modem
@@ -0,0 +1,152 @@
+#!/bin/sh /etc/rc.common
+
+START=25
+USE_PROCD=1
+
+SPRD_AT_PORT="/dev/stty_nr31"
+
+valid_pin() {
+	[ -z "$1" ] && return 0
+	[ ${#1} -ge 4 ] && [ ${#1} -le 8 ] || return 1
+	case "$1" in *[!0-9]*) return 1;; esac
+	return 0
+}
+
+valid_apn() {
+	[ -n "$1" ] && [ ${#1} -le 100 ] || return 1
+	case "$1" in *[!A-Za-z0-9.-]*|.*|*.|*..*) return 1;; esac
+	return 0
+}
+
+valid_pdn() {
+	case "$1" in ''|*[!0-9]*) return 1;; esac
+	[ "$1" -ge 1 ] && [ "$1" -le 16 ]
+}
+
+valid_at_port() {
+	case "$1" in /dev/stty_nr[0-9]*|/dev/ttyUSB[0-9]*|/dev/ttyACM[0-9]*) [ -c "$1" ];; *) return 1;; esac
+}
+
+sprd_at_cmd() {
+	local cmd="$1" t="${2:-2}"
+	local f
+	[ -c "$SPRD_AT_PORT" ] || return 1
+	f=$(mktemp /tmp/sprd-at.XXXXXX) || return 1
+	(cat "$SPRD_AT_PORT" > "$f" 2>/dev/null) &
+	local p=$!
+	printf '%s\r' "$cmd" > "$SPRD_AT_PORT"
+	sleep "$t"
+	kill $p 2>/dev/null
+	wait $p 2>/dev/null
+	cat "$f" 2>/dev/null
+	rm -f "$f"
+}
+
+service_triggers() {
+	procd_add_config_trigger "config.change" "network" /etc/init.d/sprd-modem reload
+}
+
+start_service() {
+	local apn pin pdptype pdn atport
+	apn=$(uci -q get network.modem.apn)
+	pin=$(uci -q get network.modem.pin)
+	pdptype=$(uci -q get network.modem.pdptype)
+	pdn=$(uci -q get network.modem.pdn)
+	atport=$(uci -q get network.modem.atport)
+	apn="${apn:-internet}"
+	pdptype="${pdptype:-IPV4V6}"
+	pdn="${pdn:-1}"
+
+	pdptype=$(echo "$pdptype" | tr 'a-z' 'A-Z')
+	case "$pdptype" in IP|IPV6|IPV4V6) ;; *) logger -t "sprd-modem" "invalid pdptype"; return 1;; esac
+	valid_apn "$apn" || { logger -t "sprd-modem" "invalid apn"; return 1; }
+	valid_pin "$pin" || { logger -t "sprd-modem" "invalid pin"; return 1; }
+	valid_pdn "$pdn" || { logger -t "sprd-modem" "invalid pdn"; return 1; }
+	if [ -n "$atport" ]; then
+		valid_at_port "$atport" || { logger -t "sprd-modem" "invalid atport"; return 1; }
+		SPRD_AT_PORT="$atport"
+	fi
+
+	logger -t "sprd-modem" "config: apn=$apn pdptype=$pdptype pdn=$pdn"
+
+	case "$pdptype" in
+		*IPV6*|*V6*) ifup modem6 2>/dev/null ;;
+		*)
+			ifdown modem6 2>/dev/null
+			sleep 1
+			ip -6 addr flush dev pcie0 scope global 2>/dev/null
+			killall odhcp6c 2>/dev/null
+			;;
+	esac
+
+	local w=0
+	while [ ! -c "$SPRD_AT_PORT" ] && [ $w -lt 60 ]; do sleep 2; w=$((w+2)); done
+	[ -c "$SPRD_AT_PORT" ] || { logger -t "sprd-modem" "AT port not found!"; return 1; }
+	w=0
+	while [ ! -d "/sys/class/net/pcie0" ] && [ $w -lt 60 ]; do sleep 2; w=$((w+2)); done
+
+	logger -t "sprd-modem" "modem detected, init"
+	sprd_at_cmd "AT" 2 >/dev/null
+	sprd_at_cmd "ATE1" 2 >/dev/null
+	sprd_at_cmd "AT+CFUN=1" 5 >/dev/null
+	sleep 2
+
+	if [ -n "$pin" ]; then
+		local cpin=$(sprd_at_cmd "AT+CPIN?" 3)
+		if echo "$cpin" | grep -q "SIM PIN"; then
+			logger -t "sprd-modem" "unlocking PIN"
+			sprd_at_cmd "AT+CPIN=$pin" 5 >/dev/null
+			sleep 3
+		elif echo "$cpin" | grep -q "READY"; then
+			logger -t "sprd-modem" "SIM ready"
+		fi
+	fi
+
+	sprd_at_cmd "AT+CGDCONT=${pdn},\"${pdptype}\",\"${apn}\"" 5 >/dev/null
+
+	logger -t "sprd-modem" "waiting for registration..."
+	local i=0 stat=""
+	while [ $i -lt 90 ]; do
+		local creg=$(sprd_at_cmd "AT+CEREG?" 3)
+		stat=$(echo "$creg" | grep "+CEREG:" | awk -F, '{print $2}' | tr -d ' \r')
+		[ "$stat" = "1" ] || [ "$stat" = "5" ] && break
+		sleep 1; i=$((i+1))
+	done
+	[ "$stat" = "1" ] || [ "$stat" = "5" ] || { logger -t "sprd-modem" "reg failed"; return 1; }
+
+	logger -t "sprd-modem" "registered, dialing"
+	sprd_at_cmd "AT^NDISDUN=\"vpcie0\",0,${pdn}" 5 >/dev/null
+	local ok=0 j=0
+	while [ $j -lt 30 ]; do
+		local r=$(sprd_at_cmd "AT^NDISDUN=\"vpcie0\",1,${pdn}" 3)
+		if echo "$r" | grep -qi "ERROR"; then
+			sprd_at_cmd "AT^NDISDUN=\"vpcie0\",0,${pdn}" 3 >/dev/null; sleep 1
+		else
+			ok=1; break
+		fi
+		j=$((j+1))
+	done
+	[ "$ok" -eq 1 ] || { logger -t "sprd-modem" "dial failed"; return 1; }
+
+	logger -t "sprd-modem" "dial ok, bringing up pcie0"
+	ip link set pcie0 up
+
+	case "$pdptype" in
+		IP)
+			ifdown modem6 2>/dev/null
+			killall odhcp6c 2>/dev/null
+			ip -6 addr flush dev pcie0 scope global 2>/dev/null
+			logger -t "sprd-modem" "IPv4-only mode, IPv6 disabled"
+			;;
+		*)
+			ifup modem6 2>/dev/null
+			logger -t "sprd-modem" "dual-stack mode, modem6 enabled"
+			;;
+	esac
+
+	logger -t "sprd-modem" "modem ready"
+}
+
+reload_service() {
+	start_service
+}
\ No newline at end of file
