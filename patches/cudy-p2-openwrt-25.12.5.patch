+#if defined(CONFIG_DEBUG_FS)
+void sipc_debug_putline(struct seq_file *m, char c, int n)
+{
+	char buf[300];
+	int i, max, len;
+
+	/* buf will end with '\n' and 0 */
+	max = ARRAY_SIZE(buf) - 2;
+	len = (n > max) ? max : n;
+
+	for (i = 0; i < len; i++)
+		buf[i] = c;
+
+	buf[i] = '\n';
+	buf[i + 1] = 0;
+
+	seq_puts(m, buf);
+}
+EXPORT_SYMBOL_GPL(sipc_debug_putline);
