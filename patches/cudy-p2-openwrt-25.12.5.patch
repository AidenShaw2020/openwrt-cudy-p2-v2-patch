+	spinlock_t irq_lock; /* irq spinlock */
+	spinlock_t bar_lock; /* bar spinlock */
+	spinlock_t set_irq_lock; /* set irq spinlock */
+	spinlock_t set_bar_lock; /* set bar spinlock */
+	unsigned long bar_res;
+
+	u32 base_irq;
