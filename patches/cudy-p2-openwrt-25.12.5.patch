+	if (ret)
+		return ret;
+
+	ret = sscanf((char *)data_buf, "%4hhx %4hhx\n", &debug_cmd[0],
+		     &debug_cmd[1]);
+	if (ret != 2)
+		return -EINVAL;
+	if (debug_cmd[0] >= SIPA_NIC_MAX)
+		return -EINVAL;
