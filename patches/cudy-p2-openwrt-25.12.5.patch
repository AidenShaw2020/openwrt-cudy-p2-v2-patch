index 0000000000..90afd411a6
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/usr/sbin/sprd-modem-connect
@@ -0,0 +1,137 @@
+#!/bin/sh
+
+SPRD_AT_PORT="$(uci -q get network.modem.atport)"
+SPRD_AT_PORT="${SPRD_AT_PORT:-/dev/stty_nr31}"
+SPRD_AT_TIMEOUT=5
+LOCK=/var/lock/modem-status.lock
+IFACE="pcie0"
+
+apn="$(uci -q get network.modem.apn)"
+pdptype="$(uci -q get network.modem.pdptype)"
+pin="$(uci -q get network.modem.pin)"
+pdn="$(uci -q get network.modem.pdn)"
+apn="${apn:-internet}"
+pdptype="${pdptype:-IPV4V6}"
+pdn="${pdn:-1}"
+pdptype=$(echo "$pdptype" | tr 'a-z' 'A-Z')
+
+mkdir -p /var/lock
+exec 200>"$LOCK"
+flock -x 200
+
+sprd_at_cmd() {
+	local cmd="$1"
+	local timeout="${2:-$SPRD_AT_TIMEOUT}"
+	local respfile rpid
+	[ -c "$SPRD_AT_PORT" ] || return 1
+	respfile=$(mktemp /tmp/sprd-at.XXXXXX) || return 1
+	(cat "$SPRD_AT_PORT" > "$respfile" 2>/dev/null) &
+	rpid=$!
+	printf '%s\r' "$cmd" > "$SPRD_AT_PORT"
+	sleep "$timeout"
+	kill "$rpid" 2>/dev/null
+	wait "$rpid" 2>/dev/null
+	cat "$respfile" 2>/dev/null
+	rm -f "$respfile"
+}
+
+wait_for_path() {
+	local type="$1" path="$2" limit="$3" waited=0
+	while [ "$waited" -lt "$limit" ]; do
+		case "$type" in
+			char) [ -c "$path" ] && return 0 ;;
+			dir) [ -d "$path" ] && return 0 ;;
+		esac
+		sleep 1
+		waited=$((waited + 1))
+	done
+	return 1
+}
+
+unlock_pin() {
+	local cpin_status cpin_resp
+	cpin_status=$(sprd_at_cmd "AT+CPIN?" 3)
+	logger -t "sprd-modem" "CPIN: $cpin_status"
+	if echo "$cpin_status" | grep -q "SIM PIN"; then
+		[ -n "$pin" ] || { logger -t "sprd-modem" "SIM PIN required"; return 1; }
+		logger -t "sprd-modem" "unlocking SIM PIN"
+		cpin_resp=$(sprd_at_cmd "AT+CPIN=$pin" 5)
+		echo "$cpin_resp" | grep -qi "OK" || { logger -t "sprd-modem" "PIN failed: $cpin_resp"; return 1; }
+		sleep 3
+	elif echo "$cpin_status" | grep -q "READY"; then
+		logger -t "sprd-modem" "SIM ready"
+	elif echo "$cpin_status" | grep -q "SIM PUK"; then
+		logger -t "sprd-modem" "SIM PUK locked"
+		return 1
+	fi
+	return 0
+}
+
+case "$pdptype" in
+	IP|IPV6|IPV4V6) ;;
+	*) logger -t "sprd-modem" "invalid pdptype: $pdptype"; exit 1 ;;
+esac
+
+logger -t "sprd-modem" "config: apn=$apn pdptype=$pdptype pdn=$pdn"
+wait_for_path char "$SPRD_AT_PORT" 30 || { logger -t "sprd-modem" "no AT port $SPRD_AT_PORT"; exit 1; }
+wait_for_path dir "/sys/class/net/$IFACE" 30 || { logger -t "sprd-modem" "no netdev $IFACE"; exit 1; }
+
+logger -t "sprd-modem" "modem init on $IFACE"
+sprd_at_cmd "AT" 2 >/dev/null
+sprd_at_cmd "ATE1" 2 >/dev/null
+sprd_at_cmd "AT+CFUN=1" 5 >/dev/null
+sleep 2
+unlock_pin || exit 1
+sprd_at_cmd "AT+CGDCONT=${pdn},\"${pdptype}\",\"${apn}\"" 5 >/dev/null
+
+logger -t "sprd-modem" "waiting for registration"
+i=0
+stat=""
+while [ "$i" -lt 90 ]; do
+	creg=$(sprd_at_cmd "AT+CEREG?" 3)
+	stat=$(echo "$creg" | grep "+CEREG:" | awk -F, '{print $2}' | tr -d ' \r')
+	[ "$stat" = "1" ] || [ "$stat" = "5" ] && break
+	sleep 1
+	i=$((i + 1))
+done
+[ "$stat" = "1" ] || [ "$stat" = "5" ] || { logger -t "sprd-modem" "no registration"; exit 1; }
+
+logger -t "sprd-modem" "dialing"
+sprd_at_cmd "AT^NDISDUN=\"vpcie0\",0,${pdn}" 5 >/dev/null
+j=0
+while [ "$j" -lt 30 ]; do
+	resp=$(sprd_at_cmd "AT^NDISDUN=\"vpcie0\",1,${pdn}" 3)
+	if echo "$resp" | grep -qi "ERROR"; then
+		sprd_at_cmd "AT^NDISDUN=\"vpcie0\",0,${pdn}" 3 >/dev/null
+		sleep 1
+	else
+		logger -t "sprd-modem" "dial ok, starting DHCP interfaces"
+		ip link set "$IFACE" up
+		flock -u 200 2>/dev/null || true
+		case "$pdptype" in
+			IP)
+				ifdown modem6 2>/dev/null || true
+				killall odhcp6c 2>/dev/null || true
+				ip -6 addr flush dev "$IFACE" scope global 2>/dev/null || true
+				ifup modem 2>/dev/null || true
+				logger -t "sprd-modem" "IPv4-only mode, modem6 disabled"
+				;;
+			IPV6)
+				ifdown modem 2>/dev/null || true
+				killall udhcpc 2>/dev/null || true
+				ifup modem6 2>/dev/null || true
+				logger -t "sprd-modem" "IPv6-only mode, modem disabled"
+				;;
+			*)
+				ifup modem 2>/dev/null || true
+				ifup modem6 2>/dev/null || true
+				logger -t "sprd-modem" "dual-stack mode, modem and modem6 enabled"
+				;;
+		esac
+		exit 0
+	fi
+	j=$((j + 1))
+done
+
+logger -t "sprd-modem" "dial failed"
+exit 1
