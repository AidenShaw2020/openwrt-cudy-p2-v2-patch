+#!/bin/sh /etc/rc.common
+START=98
+USE_PROCD=1
+
+start_service() {
+	procd_open_instance
+	procd_set_param command /bin/sh -c 'while true; do /usr/sbin/internet-led-status >/dev/null 2>&1; sleep 5; done'
+	procd_set_param respawn 60 5 0
+	procd_close_instance
+}
