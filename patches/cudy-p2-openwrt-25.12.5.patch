+		o.default = 'IPV4V6';
+
+		o = s.option(form.Value, 'pdn', _('PDN Profile'));
+		o.placeholder = '1'; o.default = '1'; o.datatype = 'range(1,16)';
+
+		o = s.option(form.Value, 'atport', _('AT Command Port'));
+		o.placeholder = '/dev/stty_nr31'; o.default = '/dev/stty_nr31'; o.rmempty = true;
+		o.validate = function(section_id, value) { return !value || /^\/dev\/(stty_nr|ttyUSB|ttyACM)[0-9]+$/.test(value) ? true : _('Invalid AT command port'); };
