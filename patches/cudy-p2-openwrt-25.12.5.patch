--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/usr/sbin/internet-led-status
@@ -0,0 +1,63 @@
+#!/bin/sh
+STATE=/tmp/internet-led-color
+
+set_wan_led() {
+	local color="$1"
+	[ -n "$color" ] || return 0
+	[ "$(cat "$STATE" 2>/dev/null)" = "$color" ] && return 0
+	echo "$color" > "$STATE" 2>/dev/null
+	/usr/sbin/led-color wan "$color"
+}
+
+has_v4_default() {
+	ip -4 route show default 2>/dev/null | grep -q .
+}
+
+has_v6_default() {
+	ip -6 route show default 2>/dev/null | grep -q .
+}
+
+v4_dns_list() {
+	awk '/^nameserver / && $2 !~ /:/ { print $2 }' /tmp/resolv.conf.d/resolv.conf.auto 2>/dev/null
+}
+
+v6_dns_list() {
+	awk '/^nameserver / && $2 ~ /:/ { print $2 }' /tmp/resolv.conf.d/resolv.conf.auto 2>/dev/null
+}
+
+ping_v4_any() {
+	local host
+	for host in $(v4_dns_list) 1.1.1.1 8.8.8.8; do
+		ping -c 1 -W 1 "$host" >/dev/null 2>&1 && return 0
+	done
+	return 1
+}
+
+ping_v6_any() {
+	local host
+	for host in $(v6_dns_list) 2606:4700:4700::1111 2001:4860:4860::8888; do
+		ping -6 -c 1 -W 1 "$host" >/dev/null 2>&1 && return 0
+		ping6 -c 1 -W 1 "$host" >/dev/null 2>&1 && return 0
+	done
+	return 1
+}
+
+if has_v4_default; then
+	if ping_v4_any; then
+		set_wan_led white
+	else
+		set_wan_led yellow
+	fi
+	exit 0
+fi
+
+if has_v6_default; then
+	if ping_v6_any; then
+		set_wan_led white
+	else
+		set_wan_led yellow
+	fi
+	exit 0
+fi
+
+set_wan_led red
