index 0000000000..2e397865b9
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/etc/uci-defaults/15_sprd-pcie-modem
@@ -0,0 +1,27 @@
+#!/bin/sh
+# Auto-configure SPRD PCIe modem interface for Cudy P2
+
+. /lib/functions.sh
+
+board=$(board_name)
+case "$board" in
+cudy,p2-v2)
+	uci -q get network.modem && exit 0
+
+	uci batch <<-EOF
+		set network.modem=interface
+		set network.modem.proto='sprd_pcie'
+		set network.modem.apn='internet'
+		set network.modem.pdptype='IPV4V6'
+		set network.modem.pdn='1'
+		set network.modem.atport='/dev/stty_nr31'
+		set network.modem.metric='40'
+		commit network
+
+		add_list firewall.@zone[1].network='modem'
+		commit firewall
+	EOF
+	;;
+esac
+
+exit 0
diff --git a/target/linux/mediatek/filogic/base-files/lib/netifd/proto/sprd-modem.sh b/target/linux/mediatek/filogic/base-files/lib/netifd/proto/sprd-modem.sh
new file mode 100755
index 0000000000..070d0cc13a
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/lib/netifd/proto/sprd-modem.sh
@@ -0,0 +1,158 @@
+#!/bin/sh
+
+[ -n "$INCLUDE_ONLY" ] || {
+	. /lib/functions.sh
+	. ../netifd-proto.sh
+	init_proto "$@"
+}
+
+SPRD_AT_PORT="/dev/stty_nr31"
+SPRD_AT_TIMEOUT=5
+
+valid_pin() {
+	[ -z "$1" ] && return 0
+	[ ${#1} -ge 4 ] && [ ${#1} -le 8 ] || return 1
+	case "$1" in *[!0-9]*) return 1;; esac
+	return 0
+}
+
+valid_apn() {
+	[ -n "$1" ] && [ ${#1} -le 100 ] || return 1
+	case "$1" in *[!A-Za-z0-9.-]*|.*|*.|*..*) return 1;; esac
+	return 0
+}
+
+valid_pdn() {
+	case "$1" in ''|*[!0-9]*) return 1;; esac
+	[ "$1" -ge 1 ] && [ "$1" -le 16 ]
+}
+
+valid_at_port() {
+	case "$1" in /dev/stty_nr[0-9]*|/dev/ttyUSB[0-9]*|/dev/ttyACM[0-9]*) return 0;; *) return 1;; esac
+}
+
+sprd_at_cmd() {
+	local cmd="$1"
+	local timeout="${2:-$SPRD_AT_TIMEOUT}"
+	local respfile
+	[ -c "$SPRD_AT_PORT" ] || return 1
+	respfile=$(mktemp /tmp/sprd-at.XXXXXX) || return 1
+	(cat "$SPRD_AT_PORT" > "$respfile" 2>/dev/null) &
+	local rpid=$!
+	printf '%s\r' "$cmd" > "$SPRD_AT_PORT"
+	sleep "$timeout"
+	kill $rpid 2>/dev/null
+	wait $rpid 2>/dev/null
+	cat "$respfile" 2>/dev/null
+	rm -f "$respfile"
+}
+
+sprd_unlock_pin() {
+	local cpin_status=$(sprd_at_cmd "AT+CPIN?" 3)
+	logger -t "sprd-modem" "$1: CPIN: $cpin_status"
+	if echo "$cpin_status" | grep -q "SIM PIN"; then
+		logger -t "sprd-modem" "$1: unlocking SIM PIN"
+		local cpin_resp=$(sprd_at_cmd "AT+CPIN=$pin" 5)
+		echo "$cpin_resp" | grep -qi "OK" || { logger -t "sprd-modem" "$1: PIN failed"; return 1; }
+		sleep 3
+	elif echo "$cpin_status" | grep -q "READY"; then
+		logger -t "sprd-modem" "$1: SIM ready"
+	elif echo "$cpin_status" | grep -q "SIM PUK"; then
+		logger -t "sprd-modem" "$1: SIM PUK locked!"; return 1
+	fi
+	return 0
+}
+
+proto_sprd_modem_init_config() {
+	renew_handler=1
+	proto_config_add_string apn
+	proto_config_add_string pdptype
+	proto_config_add_string pin
+	proto_config_add_int pdn
+	proto_config_add_string atport
+	proto_config_add_string hostname
+	proto_config_add_string clientid
+	proto_config_add_string vendorid
+}
+
+proto_sprd_modem_setup() {
+	local interface="$1"
+	local iface="$2"
+	local apn pdptype pin pdn atport hostname clientid vendorid
+	json_get_vars apn pdptype pin pdn atport hostname clientid vendorid
+	apn="${apn:-internet}"
+	pdptype="${pdptype:-IPV4V6}"
+	pdn="${pdn:-1}"
+	pdptype=$(echo "$pdptype" | tr 'a-z' 'A-Z')
+	case "$pdptype" in IP|IPV6|IPV4V6) ;; *) proto_notify_error "$interface" INVALID_PDPTYPE; return 1;; esac
+	valid_apn "$apn" || { proto_notify_error "$interface" INVALID_APN; return 1; }
+	valid_pin "$pin" || { proto_notify_error "$interface" INVALID_PIN; return 1; }
+	valid_pdn "$pdn" || { proto_notify_error "$interface" INVALID_PDN; return 1; }
+	if [ -n "$atport" ]; then
+		valid_at_port "$atport" || { proto_notify_error "$interface" INVALID_ATPORT; return 1; }
+		SPRD_AT_PORT="$atport"
+	fi
+	local wait=0
+	while [ ! -c "$SPRD_AT_PORT" ] && [ $wait -lt 30 ]; do sleep 1; wait=$((wait + 1)); done
+	[ -c "$SPRD_AT_PORT" ] || { proto_notify_error "$interface" NO_AT_PORT; return 1; }
+	wait=0
+	while [ ! -d "/sys/class/net/$iface" ] && [ $wait -lt 30 ]; do sleep 1; wait=$((wait + 1)); done
+	logger -t "sprd-modem" "$interface: modem init on $iface"
+	sprd_at_cmd "AT" 2 >/dev/null
+	sprd_at_cmd "ATE1" 2 >/dev/null
+	sprd_at_cmd "AT+CFUN=1" 5 >/dev/null
+	sleep 2
+	if [ -n "$pin" ]; then
+		sprd_unlock_pin "$interface" || { proto_notify_error "$interface" PIN_FAILED; return 1; }
+	fi
+	sprd_at_cmd "AT+CGDCONT=${pdn},\"${pdptype}\",\"${apn}\"" 5 >/dev/null
+	logger -t "sprd-modem" "$interface: waiting for registration..."
+	local i=0 stat=""
+	while [ $i -lt 90 ]; do
+		local creg=$(sprd_at_cmd "AT+CEREG?" 3)
+		stat=$(echo "$creg" | grep "+CEREG:" | awk -F, '{print $2}' | tr -d ' \r')
+		[ "$stat" = "1" ] || [ "$stat" = "5" ] && break
+		sleep 1; i=$((i + 1))
+	done
+	[ "$stat" = "1" ] || [ "$stat" = "5" ] || { proto_notify_error "$interface" NO_REGISTRATION; return 1; }
+	logger -t "sprd-modem" "$interface: dialing..."
+	sprd_at_cmd "AT^NDISDUN=\"vpcie0\",0,${pdn}" 5 >/dev/null
+	local dial_ok=0 j=0
+	while [ $j -lt 30 ]; do
+		local resp=$(sprd_at_cmd "AT^NDISDUN=\"vpcie0\",1,${pdn}" 3)
+		if echo "$resp" | grep -qi "ERROR"; then
+			sprd_at_cmd "AT^NDISDUN=\"vpcie0\",0,${pdn}" 3 >/dev/null; sleep 1
+		else
+			dial_ok=1; break
+		fi
+		j=$((j + 1))
+	done
+	[ "$dial_ok" -eq 1 ] || { proto_notify_error "$interface" DIAL_FAILED; return 1; }
+	logger -t "sprd-modem" "$interface: dial ok, starting DHCP on $iface"
+	proto_init_update "$iface" 1
+	proto_send_update "$interface"
+	proto_export "INTERFACE=$interface"
+	proto_run_command "$interface" udhcpc -p /var/run/udhcpc-$interface.pid -s /lib/netifd/dhcp.script -f -t 0 -i "$iface"
+	[ -x /usr/sbin/odhcp6c ] && {
+		INTERFACE="$interface" odhcp6c -s /lib/netifd/dhcpv6.script -P 0 -t 5 "$iface" &
+		logger -t "sprd-modem" "$interface: started odhcp6c for IPv6"
+	}
+}
+
+proto_sprd_modem_renew() {
+	local interface="$1"
+	local sigusr1=$(kill -l SIGUSR1)
+	[ -n "$sigusr1" ] && proto_kill_command "$interface" $sigusr1
+}
+
+proto_sprd_modem_teardown() {
+	local interface="$1" pdn
+	json_get_vars pdn
+	pdn="${pdn:-1}"
+	valid_pdn "$pdn" || pdn=1
+	[ -c "$SPRD_AT_PORT" ] && sprd_at_cmd "AT^NDISDUN=\"vpcie0\",2,${pdn}" 3 >/dev/null
+	killall odhcp6c 2>/dev/null
+	proto_kill_command "$interface"
+}
+
+[ -n "$INCLUDE_ONLY" ] || { add_protocol sprd_modem; }
