+	void __iomem *bar_vir[BAR_MAX];
+	void __iomem *cpu_vir[BAR_MAX];
+	dma_addr_t src_addr[BAR_MAX];
+	dma_addr_t target_addr[BAR_MAX];
+	size_t map_size[BAR_MAX];
