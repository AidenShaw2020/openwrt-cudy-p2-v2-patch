+static int
+ipa_common_fifo_hal_set_intr_drop_packet(enum sipa_cmn_fifo_index id,
+					 struct sipa_cmn_fifo_cfg_tag *cfg_base,
+					 u32 enable, sipa_irq_notify_cb cb)
+{
