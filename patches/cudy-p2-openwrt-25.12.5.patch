+	value = readl_relaxed(base + DOOR_BELL_STATUS);
+	if (value & DOOR_BELL_IRQ_VALUE(irq))
+		writel_relaxed(value & (~DOOR_BELL_IRQ_VALUE(irq)),
+			       base + DOOR_BELL_STATUS);
+	spin_unlock(&ep_dev->set_irq_lock);
+
+	return 0;
+}
