+						 ipa->cmn_fifo_cfg),
+		ipa->hal_ops.get_rx_full_status(SIPA_FIFO_PCIE_DL,
+						ipa->cmn_fifo_cfg));
+	seq_printf(
+		s,
+		"pcie ul tx fifo empty = %d full = %d rx fifo empty = %d full = %d\n",
+		ipa->hal_ops.get_tx_empty_status(SIPA_FIFO_PCIE_UL,
