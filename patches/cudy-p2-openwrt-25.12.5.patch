--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/usr/sbin/modem-led-status
@@ -0,0 +1,72 @@
+#!/bin/sh
+STATE=/tmp/modem-led-color
+BAD_COUNT=/tmp/modem-led-bad-count
+
+set_mobile_led() {
+	local color="$1"
+	[ -n "$color" ] || return 0
+	[ "$(cat "$STATE" 2>/dev/null)" = "$color" ] && return 0
+	echo "$color" > "$STATE" 2>/dev/null
+	/usr/sbin/led-color mobile "$color"
+}
+
+has_modem_ip() {
+	ip -4 addr show dev pcie0 2>/dev/null | grep -q 'inet ' && return 0
+	ip -6 addr show dev pcie0 2>/dev/null | grep -q 'scope global' && return 0
+	return 1
+}
+
+bad_registration() {
+	local count
+	count=$(cat "$BAD_COUNT" 2>/dev/null || echo 0)
+	count=$((count + 1))
+	echo "$count" > "$BAD_COUNT" 2>/dev/null
+	[ "$count" -ge 3 ] && set_mobile_led red
+}
+
+clear_bad_registration() {
+	rm -f "$BAD_COUNT" 2>/dev/null
+}
+
+status=$(cat /tmp/modem-status.json 2>/dev/null || true)
+sim=$(printf '%s' "$status" | sed -n 's/.*"sim":"\([^"]*\)".*/\1/p')
+reg=$(printf '%s' "$status" | sed -n 's/.*"reg":"\([^"]*\)".*/\1/p')
+
+case "$sim" in
+	*"SIM PIN"*)
+		clear_bad_registration
+		set_mobile_led red
+		exit 0
+		;;
+esac
+
+case "$reg" in
+	Registered*)
+		clear_bad_registration
+		if has_modem_ip; then
+			set_mobile_led white
+		else
+			set_mobile_led yellow
+		fi
+		;;
+	"")
+		clear_bad_registration
+		if has_modem_ip; then
+			set_mobile_led white
+		fi
+		;;
+	*Denied*|*Searching*|*searching*|*"Not registered"*|*"not registered"*|*"No service"*|*"no service"*)
+		if has_modem_ip; then
+			clear_bad_registration
+			set_mobile_led white
+		else
+			bad_registration
+		fi
+		;;
+	*)
+		if has_modem_ip; then
+			clear_bad_registration
+			set_mobile_led white
+		fi
+		;;
+esac
