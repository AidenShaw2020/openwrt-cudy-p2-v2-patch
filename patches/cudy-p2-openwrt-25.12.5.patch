+static struct pci_driver
+	sprd_pci_ep_dev_driver = { .name = DRV_MODULE_NAME,
+				   .id_table = sprd_pci_ep_dev_tbl,
+				   .probe = sprd_pci_ep_dev_probe,
+				   .remove = sprd_pci_ep_dev_remove,
+				   .driver = {
+					   .pm = &sprd_pci_ep_pm,
+				   } };
+//module_pci_driver(sprd_pci_ep_dev_driver);
