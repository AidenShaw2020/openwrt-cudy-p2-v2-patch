+	pr_info("PCIe: link_down IRQ for RC=%d\n", qcom_pcie->rc_idx);
+
+	qcom_pcie_notify_client(qcom_pcie, QCOM_PCIE_EVENT_LINKDOWN);
+	return IRQ_HANDLED;
+}
