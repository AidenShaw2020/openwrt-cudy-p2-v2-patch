+'use strict';
+'require rpc';
+'require form';
+'require network';
+
+var callFileRead = rpc.declare({
+	object: 'file',
+	method: 'read',
+	params: ['path'],
+	expect: { data: '' },
+	filter: function(value) { return value.trim() }
+});
+
+function validateApn(value) {
+	return /^[A-Za-z0-9.-]{1,100}$/.test(value) && value.charAt(0) !== '.' && value.charAt(value.length - 1) !== '.' && value.indexOf('..') === -1;
+}
+
+return network.registerProtocol('sprd_modem', {
+	getI18n: function() { return _('SPRD Modem (MeiG 5G)'); },
+	isFloating: function() { return false; },
+	isVirtual: function() { return false; },
+	renderFormOptions: function(s) {
+		var o;
+		o = s.taboption('general', form.Value, 'pin', _('SIM PIN'), _('Leave empty if SIM has no PIN'));
+		o.password = true; o.rmempty = true;
+		o.validate = function(section_id, value) { return !value || /^[0-9]{4,8}$/.test(value) ? true : _('Invalid SIM PIN'); };
+		o = s.taboption('general', form.Value, 'apn', _('APN'), _('Access Point Name'));
+		o.default = 'internet'; o.rmempty = false;
+		o.validate = function(section_id, value) { return validateApn(value) ? true : _('Invalid APN'); };
+		o = s.taboption('general', form.ListValue, 'pdptype', _('PDP Type'));
+		o.value('IP', _('IPv4')); o.value('IPV6', _('IPv6')); o.value('IPV4V6', _('IPv4/IPv6'));
+		o.default = 'IPV4V6';
+		o = s.taboption('general', form.Value, 'pdn', _('PDN Profile'));
+		o.placeholder = '1'; o.default = '1'; o.datatype = 'range(1,16)';
+		o = s.taboption('advanced', form.Value, 'atport', _('AT Command Port'));
+		o.placeholder = '/dev/stty_nr31'; o.default = '/dev/stty_nr31'; o.rmempty = true;
+		o.validate = function(section_id, value) { return !value || /^\/dev\/(stty_nr|ttyUSB|ttyACM)[0-9]+$/.test(value) ? true : _('Invalid AT command port'); };
+		o = s.taboption('advanced', form.Value, 'hostname', _('Hostname to send when requesting DHCP'));
+		o.datatype = 'or(hostname, "*")';
+		o.load = function(section_id) {
+			return callFileRead('/proc/sys/kernel/hostname').then(L.bind(function(hostname) {
+				this.placeholder = hostname;
+				return form.Value.prototype.load.apply(this, [section_id]);
+			}, this));
+		};
+		s.taboption('advanced', form.Value, 'clientid', _('Client ID to send when requesting DHCP'));
+		s.taboption('advanced', form.Value, 'vendorid', _('Vendor Class to send when requesting DHCP'));
+	}
+});
