+static const struct file_operations modem_ctrl_fops = {
+	.open = modem_ctrl_open,
+	.release = modem_ctrl_release,
+	.read = modem_ctrl_read,
+	.write = modem_ctrl_write,
+	.unlocked_ioctl = modem_ctrl_ioctl,
+	.owner = THIS_MODULE,
+	.llseek = default_llseek,
+};
