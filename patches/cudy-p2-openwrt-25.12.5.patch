--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/usr/sbin/led-color
@@ -0,0 +1,16 @@
+#!/bin/sh
+# Set one color in a three-color LED group, e.g. wan or mobile.
+group="$1"
+color="$2"
+[ -n "$group" ] && [ -n "$color" ] || exit 0
+for led in red:$group yellow:$group white:$group; do
+	[ -d "/sys/class/leds/$led" ] || continue
+	echo none > "/sys/class/leds/$led/trigger" 2>/dev/null
+	echo 0 > "/sys/class/leds/$led/brightness" 2>/dev/null
+done
+led="$color:$group"
+[ -d "/sys/class/leds/$led" ] || exit 0
+echo none > "/sys/class/leds/$led/trigger" 2>/dev/null
+brightness=$(cat "/sys/class/leds/$led/max_brightness" 2>/dev/null)
+[ -n "$brightness" ] || brightness=1
+echo "$brightness" > "/sys/class/leds/$led/brightness" 2>/dev/null
diff --git a/target/linux/mediatek/filogic/base-files/usr/sbin/modem-led-status b/target/linux/mediatek/filogic/base-files/usr/sbin/modem-led-status
