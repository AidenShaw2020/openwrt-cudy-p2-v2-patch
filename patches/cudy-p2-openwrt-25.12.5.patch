+static void smsg_pcie_first_ready(void *data)
+{
+	struct smsg_ipc *ipc = (struct smsg_ipc *)data;
+
+	if (ipc->smem_type == SMEM_PCIE)
+		smsg_ipc_smem_init(ipc);
+	else
+		pr_err("%s: pcie first ready, smem_type =%d!\n", ipc->name,
+		       ipc->smem_type);
