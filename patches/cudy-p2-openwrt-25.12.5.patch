index 0000000000..73ac961ec3
--- /dev/null
+++ b/target/linux/mediatek/filogic/base-files/usr/sbin/modem-status
@@ -0,0 +1,74 @@
+#!/bin/sh
+LOCK=/var/lock/modem-status.lock
+PORT="/dev/stty_nr31"
+CACHE="/tmp/modem-status.json"
+mkdir -p /var/lock
+exec 200>"$LOCK"
+flock -n 200 || exit 0
+[ -c "$PORT" ] || { echo '{"error":"no port"}'; exit 0; }
+
+json_escape() {
+	printf '%s' "$1" | tr -d '\r\n\t' | sed 's/\\/\\\\/g; s/"/\\"/g'
+}
+
+at() {
+	local cmd="$1" t="${2:-1}"
+	local f
+	f=$(mktemp /tmp/modem-at.XXXXXX) || return 1
+	(cat "$PORT" > "$f" 2>/dev/null) &
+	local p=$!
+	printf '%s\r' "$cmd" > "$PORT"
+	sleep "$t"
+	kill $p 2>/dev/null
+	wait $p 2>/dev/null
+	cat "$f" 2>/dev/null
+	rm -f "$f"
+}
+
+CEREG=$(at "AT+CEREG?" 1)
+RS=$(echo "$CEREG" | grep '+CEREG:' | awk -F, '{print $2}' | tr -d '\r')
+TAC=$(echo "$CEREG" | grep '+CEREG:' | awk -F, '{print $3}' | tr -d '"\r')
+CELLID=$(echo "$CEREG" | grep '+CEREG:' | awk -F, '{print $4}' | tr -d '"\r')
+case "$RS" in
+	0) REG="Not registered";; 1) REG="Registered (home)";; 2) REG="Searching";;
+	3) REG="Denied";; 5) REG="Registered (roaming)";; *) REG="State $RS";;
+esac
+COPS=$(at "AT+COPS?" 2)
+OP=$(echo "$COPS" | grep '+COPS:' | awk -F, '{print $3}' | tr -d '"\r')
+RAT=$(echo "$COPS" | grep '+COPS:' | awk -F, '{print $4}' | tr -d '\r')
+case "$RAT" in 7) RAT="4G LTE";; 9) RAT="5G NSA";; 12|13) RAT="5G SA";; *) RAT="$RAT";; esac
+LINE=$(at "AT+SGCELLINFOEX" 2 2>/dev/null | grep '+SGCELLINFOEX:' | sed 's/+SGCELLINFOEX://')
+CELLMODE="" DUPLEX="" BAND="" SGCELLID="" PCI="" EARFCN=""
+LTE_RSRP="" LTE_RSRQ="" LTE_SINR="" NR_RSRP="" NR_RSRQ="" NR_SINR="" NR_BAND="" NR_ARFCN=""
+if [ -n "$LINE" ]; then
+	CELLMODE=$(echo "$LINE" | awk -F, '{print $1}' | tr -d '\r')
+	DUPLEX=$(echo "$LINE" | awk -F, '{print $2}' | tr -d '\r')
+	EARFCN=$(echo "$LINE" | awk -F, '{print $3}' | tr -d '\r')
+	BAND=$(echo "$LINE" | awk -F, '{print $4}' | tr -d '\r')
+	SGCELLID=$(echo "$LINE" | awk -F, '{print $5}' | tr -d '\r')
+	PCI=$(echo "$LINE" | awk -F, '{print $6}' | tr -d '\r')
+	LTE_RSRP=$(echo "$LINE" | awk -F, '{print $14}' | tr -d '\r')
+	LTE_RSRQ=$(echo "$LINE" | awk -F, '{print $15}' | tr -d '\r')
+	LTE_SINR=$(echo "$LINE" | awk -F, '{print $16}' | tr -d '\r')
+	NR_RSRP=$(echo "$LINE" | awk -F, '{print $30}' | tr -d '\r')
+	NR_RSRQ=$(echo "$LINE" | awk -F, '{print $31}' | tr -d '\r')
+	NR_SINR=$(echo "$LINE" | awk -F, '{print $32}' | tr -d '\r')
+	NR_ARFCN=$(echo "$LINE" | awk -F, '{print $34}' | tr -d '\r')
+	NR_BAND=$(echo "$LINE" | awk -F, '{print $35}' | tr -d '\r')
+fi
+SIM=$(at "AT+CPIN?" 1 | grep '+CPIN:' | sed 's/+CPIN: //' | tr -d '\r')
+ICCID=$(at "AT+ICCID" 1 | grep '+ICCID:' | sed 's/+ICCID: //' | tr -d '\r')
+MODEL=$(at "AT+CGMM" 1 | grep -v '^AT' | grep -v '^OK' | head -1 | sed 's/+CGMM: //' | tr -d '\r')
+IP=$(ip -4 addr show pcie0 2>/dev/null | grep 'inet ' | awk '{print $2}')
+IP6=$(ip -6 addr show pcie0 2>/dev/null | grep 'scope global' | head -1 | awk '{print $2}')
+GW=$(ip route show dev pcie0 2>/dev/null | grep default | awk '{print $3}')
+DNS1=$(cat /tmp/resolv.conf.d/resolv.conf.auto 2>/dev/null | grep nameserver | head -1 | awk '{print $2}')
+DNS2=$(cat /tmp/resolv.conf.d/resolv.conf.auto 2>/dev/null | grep nameserver | sed -n '2p' | awk '{print $2}')
+UPTIME=$(ifstatus modem 2>/dev/null | grep '"uptime"' | awk -F: '{print $2}' | tr -d ' ,')
+
+tmp=$(mktemp /tmp/modem-status.json.XXXXXX) || exit 1
+printf '{"sim":"%s","reg":"%s","operator":"%s","rat":"%s","cellmode":"%s","duplex":"%s","band":"%s","cellid":"%s","pci":"%s","tac":"%s","earfcn":"%s","lte_rsrp":"%s","lte_rsrq":"%s","lte_sinr":"%s","nr_rsrp":"%s","nr_rsrq":"%s","nr_sinr":"%s","nr_band":"%s","nr_arfcn":"%s","model":"%s","iccid":"%s","ip":"%s","ip6":"%s","dns1":"%s","dns2":"%s","gw":"%s","uptime":"%s"}' \
+	"$(json_escape "${SIM:-?}")" "$(json_escape "${REG:-?}")" "$(json_escape "${OP:-}")" "$(json_escape "${RAT:-}")" "$(json_escape "${CELLMODE:-}")" "$(json_escape "${DUPLEX:-}")" "$(json_escape "${BAND:-}")" "$(json_escape "${SGCELLID:-}")" "$(json_escape "${PCI:-}")" "$(json_escape "${TAC:-}")" "$(json_escape "${EARFCN:-}")" "$(json_escape "${LTE_RSRP:-}")" "$(json_escape "${LTE_RSRQ:-}")" "$(json_escape "${LTE_SINR:-}")" "$(json_escape "${NR_RSRP:-}")" "$(json_escape "${NR_RSRQ:-}")" "$(json_escape "${NR_SINR:-}")" "$(json_escape "${NR_BAND:-}")" "$(json_escape "${NR_ARFCN:-}")" "$(json_escape "${MODEL:-}")" "$(json_escape "${ICCID:-}")" "$(json_escape "${IP:-}")" "$(json_escape "${IP6:-}")" "$(json_escape "${DNS1:-}")" "$(json_escape "${DNS2:-}")" "$(json_escape "${GW:-}")" "$(json_escape "${UPTIME:-}")" > "$tmp"
+chmod 0644 "$tmp" 2>/dev/null || true
+mv -f "$tmp" "$CACHE"
+cat "$CACHE"
\ No newline at end of file
diff --git a/target/linux/mediatek/filogic/base-files/usr/sbin/sprd-modem-connect b/target/linux/mediatek/filogic/base-files/usr/sbin/sprd-modem-connect
