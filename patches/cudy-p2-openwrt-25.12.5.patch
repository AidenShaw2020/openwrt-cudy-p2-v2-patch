@@ -0,0 +1,70 @@
+'use strict';
+'require fs';
+'require ui';
+
+function esc(s) {
+	return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
+		return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
+	});
+}
+function bars(val, type) {
+	if (!val || val === '?' || val === '') return 'N/A';
+	var v = parseInt(val);
+	if (isNaN(v)) return esc(val);
+	var b = 0;
+	if (v > -70) b = 5; else if (v > -80) b = 4; else if (v > -90) b = 3;
+	else if (v > -100) b = 2; else if (v > -110) b = 1;
+	var html = '';
+	for (var i = 1; i <= 5; i++) {
+		var on = i <= b;
+		var h = i * 4 + 4;
+		var color = on ? (b >= 4 ? '#2e7d32' : b >= 2 ? '#f57f17' : '#c62828') : '#ddd';
+		html += '<span style="display:inline-block;width:6px;height:' + h + 'px;background:' + color + ';margin-right:2px;border-radius:1px;vertical-align:bottom;"></span>';
+	}
+	return html + ' <small>' + esc(val) + ' dBm</small>';
+}
+function upFmt(s) {
+	if (!s || s === '?') return '-';
+	s = parseInt(s); if (isNaN(s)) return '-';
+	var d = Math.floor(s/86400), h = Math.floor((s%86400)/3600), m = Math.floor((s%3600)/60);
+	if (d) return d+'d '+h+'h '+m+'m'; if (h) return h+'h '+m+'m'; return m+'m';
+}
+function v(d, k) { return d[k] && d[k] !== '?' && d[k] !== '' ? esc(d[k]) : '-'; }
+
+return L.view.extend({
+	title: _('Mobile Network'),
+	description: _('5G modem status'),
+	load: function() {
+		return fs.read('/tmp/modem-status.json').then(function(data) {
+			try { return JSON.parse(data.trim()); } catch(e) { return { error: 'waiting' }; }
+		}).catch(function() { return { error: 'nofile' }; });
+	},
+	render: function(data) {
+		var c = E('div');
+		function fill(d) {
+			c.innerHTML = '';
+			if (d.error) { c.innerHTML = '<div class="alert-message"><p>' + esc(_('Waiting for modem status data...')) + '</p></div>'; return; }
+			var sec = function(title, rows) {
+				var h = '<div class="cbi-section"><h3>' + esc(title) + '</h3><table class="table">';
+				for (var i = 0; i < rows.length; i++)
+					h += '<tr class="tr"><td class="td left" style="width:35%;font-weight:bold">' + esc(rows[i][0]) + '</td><td class="td left">' + rows[i][1] + '</td></tr>';
+				return h + '</table></div>';
+			};
+			var html = '';
+			html += sec(_('Connection'), [[_('SIM Status'),v(d,'sim')],[_('Registration'),v(d,'reg')],[_('Operator'),v(d,'operator')],[_('Network Type'),v(d,'rat')],[_('Mode'),v(d,'cellmode')],[_('Uptime'),upFmt(d.uptime)]]);
+			html += sec(_('Cell Info'), [[_('Duplex'),v(d,'duplex')],[_('Band'),v(d,'band')],[_('EARFCN'),v(d,'earfcn')],[_('Cell ID'),v(d,'cellid')],[_('PCI'),v(d,'pci')],[_('TAC'),v(d,'tac')]]);
+			html += sec(_('LTE Signal'), [[_('RSRP'),d.lte_rsrp&&d.lte_rsrp!==''?bars(d.lte_rsrp,'rsrp'):'-'],[_('RSRQ'),d.lte_rsrq?esc(d.lte_rsrq)+' dB':'-'],[_('SINR'),d.lte_sinr?esc(d.lte_sinr)+' dB':'-']]);
+			if (d.nr_rsrp && d.nr_rsrp !== '') html += sec(_('5G NR Signal'), [[_('RSRP'),bars(d.nr_rsrp,'rsrp')],[_('RSRQ'),v(d,'nr_rsrq')+(d.nr_rsrq&&d.nr_rsrq!==''?' dB':'')],[_('SINR'),v(d,'nr_sinr')+(d.nr_sinr&&d.nr_sinr!==''?' dB':'')],[_('NR Band'),v(d,'nr_band')],[_('NR ARFCN'),v(d,'nr_arfcn')]]);
+			html += sec(_('Device'), [[_('Modem Model'),v(d,'model')],[_('ICCID'),v(d,'iccid')]]);
+			c.innerHTML = html;
+		}
+		fill(data);
+		L.Poll.add(function() {
+			fs.read('/tmp/modem-status.json').then(function(raw) {
+				try { fill(JSON.parse(raw.trim())); } catch(e) {}
+			}).catch(function() {});
+		}, 5);
+		return c;
+	},
+	handleSave: null, handleSaveApply: null, handleReset: null
+});
