@@ -0,0 +1,36 @@
+#!/bin/sh
+# Auto-configure SPRD PCIe modem interface for Cudy P2
+
+. /lib/functions.sh
+
+board=$(board_name)
+case "$board" in
+cudy,p2-v2)
+	uci -q get network.modem && exit 0
+
+	uci batch <<-EOF
+		set network.modem=interface
+		set network.modem.proto='dhcp'
+		set network.modem.device='pcie0'
+		set network.modem.apn='internet'
+		set network.modem.pdptype='IPV4V6'
+		set network.modem.pdn='1'
+		set network.modem.atport='/dev/stty_nr31'
+		set network.modem.metric='40'
+
+		set network.modem6=interface
+		set network.modem6.proto='dhcpv6'
+		set network.modem6.device='pcie0'
+		set network.modem6.reqaddress='try'
+		set network.modem6.reqprefix='no'
+		set network.modem6.metric='40'
+		commit network
+
+		add_list firewall.@zone[1].network='modem'
+		add_list firewall.@zone[1].network='modem6'
+		commit firewall
+	EOF
+	;;
+esac
+
+exit 0
