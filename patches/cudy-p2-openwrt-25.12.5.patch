+		     &debug_cmd[1], &debug_cmd[2], &debug_cmd[3],
+		     &debug_cmd[4]);
+	if (ret < 3)
+		return -EINVAL;
+	if (!sipa_reg_offset_valid(ipa, debug_cmd[0]))
+		return -EINVAL;
+
+	if (debug_cmd[2])
+		writel_relaxed(debug_cmd[1], ipa->virt_reg_addr + debug_cmd[0]);
